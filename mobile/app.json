{
  "expo": {
    "name": "Crammer's Restaurant",
    "slug": "crammers-restaurant",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "crammers",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.crammers.restaurant"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0a"
      },
      "package": "com.crammers.restaurant"
    },
    "plugins": ["expo-router", "expo-secure-store", "expo-splash-screen"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
